# ── Stage 1: Build Flutter web ────────────────────────────────────────────────
FROM ghcr.io/cirruslabs/flutter:3.35.3 AS builder

WORKDIR /app

ARG API_URL=https://bla-production-a186.up.railway.app

RUN echo "API_URL=${API_URL}" > .env

COPY pubspec.yaml pubspec.lock ./
RUN flutter pub get

COPY . .

RUN echo "API_URL=${API_URL}" > .env

RUN flutter build web --release \
    --dart-define=API_URL=${API_URL}

# ── Stage 2: Serve with nginx ─────────────────────────────────────────────────
FROM nginx:alpine

COPY --from=builder /app/build/web /usr/share/nginx/html

# nginx:alpine's official entrypoint processes /etc/nginx/templates/*.template
# at startup using envsubst — it substitutes only variables present in the
# container environment, so nginx variables like $uri are left untouched.
# Railway injects $PORT; the template writes it into the listen directive.
COPY nginx.conf /etc/nginx/templates/default.conf.template

CMD ["nginx", "-g", "daemon off;"]
