# ── Stage 1: Build Flutter web ────────────────────────────────────────────────
FROM ghcr.io/cirruslabs/flutter:3.35.3 AS builder

WORKDIR /app

ARG API_URL=https://bla-production-a186.up.railway.app

RUN echo "API_URL=${API_URL}" > .env

COPY pubspec.yaml pubspec.lock ./
RUN flutter pub get

COPY . .

RUN echo "API_URL=${API_URL}" > .env

RUN flutter build web --release \
    --dart-define=API_URL=${API_URL}

# ── Stage 2: Serve with nginx ─────────────────────────────────────────────────
FROM nginx:alpine

COPY --from=builder /app/build/web /usr/share/nginx/html

# Copy config with RAILWAY_PORT as a plain text placeholder
COPY nginx.conf /etc/nginx/conf.d/default.conf

# At startup: replace RAILWAY_PORT with the actual $PORT injected by Railway,
# then start nginx. No envsubst, no template mechanism — just sed.
CMD ["/bin/sh", "-c", "sed -i \"s/RAILWAY_PORT/$PORT/g\" /etc/nginx/conf.d/default.conf && exec nginx -g 'daemon off;'"]
