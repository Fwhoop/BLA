# ── Stage 1: Build Flutter web ────────────────────────────────────────────────
FROM ghcr.io/cirruslabs/flutter:3.35.3 AS builder

WORKDIR /app

ARG API_URL=https://bla-production-a186.up.railway.app

RUN echo "API_URL=${API_URL}" > .env

COPY pubspec.yaml pubspec.lock ./
RUN flutter pub get

COPY . .

RUN echo "API_URL=${API_URL}" > .env

RUN flutter build web --release \
    --dart-define=API_URL=${API_URL}

# ── Stage 2: Serve with nginx ─────────────────────────────────────────────────
FROM nginx:alpine

# Remove default nginx config to avoid conflicts
RUN rm /etc/nginx/conf.d/default.conf

# Copy Flutter build output
COPY --from=builder /app/build/web /usr/share/nginx/html

# nginx:alpine entrypoint auto-processes /etc/nginx/templates/*.template
# at startup — substitutes $PORT (and only env vars that exist) into the config.
# nginx variables like $uri are NOT env vars, so they are left untouched.
COPY nginx.conf /etc/nginx/templates/default.conf.template

CMD ["nginx", "-g", "daemon off;"]
