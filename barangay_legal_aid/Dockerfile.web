# ── Stage 1: Build Flutter web ────────────────────────────────────────────────
FROM ghcr.io/cirruslabs/flutter:3.35.3 AS builder

WORKDIR /app

ARG API_URL=https://bla-production-a186.up.railway.app

RUN echo "API_URL=${API_URL}" > .env

COPY pubspec.yaml pubspec.lock ./
RUN flutter pub get

COPY . .

RUN echo "API_URL=${API_URL}" > .env

RUN flutter build web --release \
    --dart-define=API_URL=${API_URL}

# ── Stage 2: Serve with nginx ─────────────────────────────────────────────────
FROM nginx:alpine

# gettext provides envsubst — required for the official nginx template mechanism
RUN apk add --no-cache gettext

# Remove the default site config so only our template config is used
RUN rm /etc/nginx/conf.d/default.conf

# Copy Flutter build output
COPY --from=builder /app/build/web /usr/share/nginx/html

# nginx:alpine entrypoint runs /docker-entrypoint.d/20-envsubst-on-templates.sh
# which processes *.template files in /etc/nginx/templates/ using envsubst,
# writing the result to /etc/nginx/conf.d/.
# Only environment variables that exist at runtime are substituted —
# nginx variables like $uri are not env vars so they pass through unchanged.
COPY nginx.conf /etc/nginx/templates/default.conf.template

CMD ["nginx", "-g", "daemon off;"]
